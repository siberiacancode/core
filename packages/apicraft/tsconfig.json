{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@siberiacancode/tsconfig/tsconfig.node.json",
  "compilerOptions": {
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
