{
  "name": "@siberiacancode/yandex-metrika",
  "type": "module",
  "version": "1.0.0",
  "description": "Yandex Metrika integration helpers",
  "author": {
    "name": "SIBERIA CAN CODE 🧊",
    "url": "https://github.com/siberiacancode"
  },
  "license": "MIT",
  "homepage": "https://github.com/siberiacancode/core",
  "repository": {
    "url": "https://github.com/siberiacancode/core"
  },
  "bugs": {
    "url": "https://github.com/siberiacancode/core/issues"
  },
  "keywords": [
    "yandex",
    "metrika",
    "analytics",
    "react"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/esm/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm type && pnpm build",
    "build": "tsdown",
    "lint": "eslint . --fix",
    "lint-inspector": "npx @eslint/config-inspector",
    "type": "tsc --noEmit",
    "format": "prettier --write .",
    "pretty": "pnpm type && pnpm lint && pnpm format"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@siberiacancode/eslint": "*",
    "@siberiacancode/prettier": "*",
    "@siberiacancode/tsconfig": "*",
    "@types/react": "^19.2.14",
    "react": "^19.2.4"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
